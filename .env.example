# 複製為 .env 後可自訂（.env 已在 .gitignore）

# 應用
BACKEND_PORT=8080
FRONTEND_PORT=8081

# MySQL（主機連線埠 3308，避免與本機 3306 / 其他專案衝突）
MYSQL_ROOT_PASSWORD=0000
MYSQL_DATABASE=toolbox
MYSQL_PORT=3308

# Redis（主機連線埠 6380，避免與本機 6379 衝突）
REDIS_PORT=6380

# Mailpit（開發用郵件測試；Web UI: http://localhost:8025）
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
